  "spotInsights": {
    "namcha_barwa": {
      "unique": "索松村不是密集打卡，而是给南迦巴瓦留天气窗口；看到山本身就是当天最大收益。",
      "history": "南迦巴瓦在雅鲁藏布大峡谷区域形成强烈高差，云雾变化极快，因此常被旅行者称作难得一见的神山。"
    },
    "gangyun_forest": {
      "unique": "杉林徒步把波密的湿润森林、雪山和高原空气集中在一天里，是全程体力要求最高的自然体验之一。",
      "history": "波密一带受印度洋水汽影响，森林景观和西藏常见的荒寒高原反差很大。"
    },
    "guoguo_turn": {
      "unique": "果果塘大拐弯用一个完整江湾把墨脱的热带湿润感拉出来，和嘎隆拉雪山路段形成强烈切换。",
      "history": "墨脱长期交通艰难，扎墨公路和嘎隆拉隧道让这条路线从艰险进藏路逐渐变成可抵达的旅行线路。"
    },
    "basum_tso": {
      "unique": "巴松措的湖色、村落和雪山关系很适合慢住，住在景区内比单纯路过更能感到它的层次。",
      "history": "巴松措是林芝重要湖泊景区，周边村落、寺庙和徒步线路共同组成多日停留空间。"
    },
    "potala_palace": {
      "unique": "布达拉宫这天不只是拍照，而是用讲解把前面一路的藏地文化线索收束起来。",
      "history": "布达拉宫是拉萨最重要的历史建筑之一，参观线路、预约时段和讲解质量会明显影响体验。"
    }
  },
