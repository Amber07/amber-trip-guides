  "spotInsights": {
    "borobudur": {
      "unique": "婆罗浮屠的清晨顺光和层层佛塔，是整条日惹文化线最稳的高光。",
      "history": "这座佛教遗迹建于中爪哇古代王朝时期，与普兰巴南一起构成日惹周边最重要的世界遗产组合。"
    },
    "prambanan": {
      "unique": "尖塔群在傍晚光线里非常立体，和婆罗浮屠的水平层叠形成鲜明对比。",
      "history": "普兰巴南是爪哇印度教建筑的代表，遗迹规模和细部雕刻都值得慢看。"
    },
    "bromo_penanjakan": {
      "unique": "银河、日出、火山群和云海可能在同一个清晨出现，是整趟行程强度最高也最出片的时刻。",
      "history": "布罗莫所在的腾格尔火山群是东爪哇最知名的火山景观带。"
    },
    "tumpak_sewu": {
      "unique": "瀑布像帘幕一样从环形峡谷边缘落下，近距离徒步会湿透但视觉冲击非常强。",
      "history": "赛武瀑布位于塞梅鲁火山区域，瀑布、峡谷和火山远景共同构成东爪哇自然线的核心。"
    },
    "padar_island": {
      "unique": "山脊两侧同时展开多色海湾，视角开阔到像游戏地图，是科莫多海岛线的标志画面。",
      "history": "帕达尔岛属于科莫多国家公园区域，干燥丘陵和海湾地形共同塑造了独特景观。"
    },
    "kalong_bats": {
      "unique": "红色日落、成群蝙蝠和回程星空连在一起，适合作为科莫多出海日的情绪收尾。",
      "history": "卡隆岛因黄昏蝙蝠群出动而成为 Labuan Bajo 周边非常受欢迎的傍晚包船点。"
    }
  },
