  "spotInsights": {
    "pena_palace": {
      "unique": "颜色强烈的浪漫主义宫殿和辛特拉山林组合，是第一天最有“落地即旅行感”的画面。",
      "history": "佩纳宫由 19 世纪葡萄牙王室扩建而成，融合摩尔、哥特、文艺复兴等复兴风格。"
    },
    "quinta_regaleira": {
      "unique": "倒置塔、地下通道和符号系统让它不像传统宫殿，更像一场神秘主义寻宝。",
      "history": "庄园在 20 世纪初由富商 Carvalho Monteiro 与建筑师 Luigi Manini 打造，处处可见炼金和骑士团意象。"
    },
    "cabo_roca": {
      "unique": "欧陆尽头感很强，适合拍“陆止于此，海始于斯”的定位照。",
      "history": "罗卡角长期被视作欧洲大陆西端象征，石碑上刻有葡萄牙诗人卡蒙斯的名句。"
    },
    "sagrada_familia": {
      "unique": "下午光线穿过彩窗时，内部空间会从建筑参观变成一场色彩体验。",
      "history": "圣家堂始建于 1882 年，高迪 1883 年接手后重塑设计，是巴塞罗那最具代表性的长期工程。"
    },
    "alhambra": {
      "unique": "Nasrid 宫的纹样、庭院水景和远望阿尔拜辛的视角，是格拉纳达的核心体验。",
      "history": "阿尔罕布拉宫是纳斯瑞德王朝时期的宫殿堡垒，也是伊斯兰艺术在伊比利亚半岛的代表。"
    },
    "plaza_espana_seville": {
      "unique": "日落时广场、瓷砖、拱廊和水面会一起变暖，适合作为塞维利亚第一天收尾。",
      "history": "西班牙广场为 1929 年伊比利亚-美洲博览会而建，半圆形建筑象征西班牙面向美洲。"
    },
    "benagil_cave": {
      "unique": "海蚀洞顶部天窗让光线直接落到洞内沙滩，是阿尔加维海岸最标志性的画面。",
      "history": "贝纳吉尔海蚀洞由石灰岩海岸长期受海浪侵蚀形成，能否接近高度依赖当天海况。"
    }
  },
